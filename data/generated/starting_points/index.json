[
  {
    "id": "ibs",
    "label": "IBS",
    "full_label": "Irritable bowel syndrome (IBS)",
    "kind": "syndrome",
    "condition_id": "ibs",
    "intro": "IBS is a syndrome label \u2014 these are the conditions worth ruling in or out,\nbest-effort sorted by how often each shows up in IBS patients. Filters\ncan help prioritise but might be imprecise.\n",
    "symptom_patterns": [
      {
        "id": "ibs-d",
        "label": "IBS-D \u2014 diarrhea-predominant",
        "description": "Loose or watery stools are the dominant feature, often urgent and occurring after meals. Cramping and bloating are common, and symptoms may be triggered by stress, food, or both.\n"
      },
      {
        "id": "ibs-c",
        "label": "IBS-C \u2014 constipation-predominant",
        "description": "Hard, infrequent, or difficult-to-pass stools dominate, often accompanied by abdominal pain and bloating that may partially improve after a bowel movement.\n"
      },
      {
        "id": "ibs-m",
        "label": "IBS-M \u2014 mixed bowel habits",
        "description": "Both diarrhea and constipation occur in the same person, sometimes alternating within days or even hours. This pattern can be particularly difficult to manage with a single treatment approach.\n"
      },
      {
        "id": "bloating-dominant",
        "label": "Bloating and gas dominant",
        "description": "Significant abdominal distension, visible bloating, and excessive gas are the primary complaints, with bowel habit changes being secondary or variable.\n"
      },
      {
        "id": "pain-dominant",
        "label": "Pain-dominant / visceral hypersensitivity pattern",
        "description": "Abdominal pain is the most disabling symptom, often out of proportion to visible gut changes, suggestive of heightened pain signalling in the gut-brain axis.\n"
      },
      {
        "id": "post-infectious",
        "label": "Post-infectious IBS (PI-IBS)",
        "description": "Symptoms began or dramatically worsened following an episode of gastroenteritis, food poisoning, or traveller's diarrhea, suggesting microbial or immune disruption as a trigger.\n"
      },
      {
        "id": "systemic",
        "label": "Symptoms beyond the gut",
        "description": "Conditions where significant symptoms appear outside the digestive system \u2014 brain fog, fatigue, skin rashes, joint pain, or widespread pain \u2014 often alongside or instead of classic gut symptoms. If gut issues come with unexplained systemic symptoms, investigating these drivers is especially worthwhile.\n"
      }
    ],
